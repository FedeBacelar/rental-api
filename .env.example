MYSQL_DATABASE=rental_api
MYSQL_USER=appuser
MYSQL_PASSWORD=apppass
MYSQL_ROOT_PASSWORD=root
MYSQL_PORT=3506

DATABASE_URL=mysql+pymysql://appuser:apppass@localhost:3506/rental_api

JWT_SECRET_KEY=dev-secret-change-me-at-least-32-bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_COOKIE_SECURE=0

OVERDUE_WORKER_ENABLED=1
OVERDUE_WORKER_RUN_ON_STARTUP=1
OVERDUE_WORKER_DAILY_TIME=00:00

CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
